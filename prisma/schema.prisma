generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  targets   WorkflowTarget[]
  incidents Incident[]
  testRuns  TestRun[]
}

model User {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("VIEWER")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  refreshTokens RefreshToken[]
  reportedIncidents Incident[] @relation("Reporter")
  assignedIncidents Incident[] @relation("Assignee")
  incidentNotes IncidentNote[]
  testRuns      TestRun[]
  auditEvents   AuditEvent[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model WorkflowTarget {
  id           String       @id @default(uuid())
  workspaceId  String
  workspace    Workspace    @relation(fields: [workspaceId], references: [id])
  name         String
  slug         String       @unique
  description  String?
  type         String
  sourceSystem String
  environment  String
  status       String       @default("ACTIVE")
  ownerId      String?
  tags         String       @default("[]")
  metadata     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  archivedAt   DateTime?
  incidents Incident[]
  testRuns  TestRun[]
}

model Incident {
  id                String           @id @default(uuid())
  workspaceId       String
  workspace         Workspace        @relation(fields: [workspaceId], references: [id])
  workflowTargetId  String
  workflowTarget    WorkflowTarget   @relation(fields: [workflowTargetId], references: [id])
  title             String
  description       String
  severity          String
  priority          String
  status            String           @default("OPEN")
  reporterId        String
  reporter          User             @relation("Reporter", fields: [reporterId], references: [id])
  assigneeId        String?
  assignee          User?            @relation("Assignee", fields: [assigneeId], references: [id])
  rootCause         String?
  resolutionSummary String?
  openedAt          DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  closedAt          DateTime?
  notes IncidentNote[]
}

model IncidentNote {
  id         String   @id @default(uuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  content    String
  createdAt  DateTime @default(now())
}

model TestRun {
  id               String         @id @default(uuid())
  workspaceId      String
  workspace        Workspace      @relation(fields: [workspaceId], references: [id])
  workflowTargetId String
  workflowTarget   WorkflowTarget @relation(fields: [workflowTargetId], references: [id])
  triggeredByUserId String
  triggeredByUser  User           @relation(fields: [triggeredByUserId], references: [id])
  type             String
  status           String
  result           String?
  startedAt        DateTime       @default(now())
  finishedAt       DateTime?
  durationMs       Int?
  inputPayload     String?
  outputPayload    String?
  normalizedError  String?
}

model LogEvent {
  id               String    @id @default(uuid())
  workspaceId      String
  workflowTargetId String?
  incidentId       String?
  testRunId        String?
  userId           String?
  level            String
  message          String
  context          String?
  timestamp        DateTime  @default(now())
}

model AuditEvent {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  details     String?
  createdAt   DateTime @default(now())
}
